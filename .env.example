# =============================================================================
# K-DATAHUB Environment Configuration
# =============================================================================
# Copy this file as .env in the project root
# Fill in all required values marked with [REQUIRED]
# NEVER commit this file to Git!
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────
# DJANGO CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

# Development mode (set to False in production)
DEBUG=True

# Django secret key (generate a new one for production)
# Generate with: python manage.py shell -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-key-change-in-production-xyzabcdef123456

# Domain configuration
BASE_DOMAIN=http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# ─────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

# For development: leave blank to use SQLite
# For production: use PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/k_datahub
DATABASE_URL=

# Use PostgreSQL? (True for production, False for local development)
USE_POSTGRES=False

# ─────────────────────────────────────────────────────────────────────────
# SUPABASE CONFIGURATION [REQUIRED FOR FILE UPLOADS]
# ─────────────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Settings → API

# Enable Supabase for file storage (True for production, False for local)
USE_SUPABASE=True

# Supabase Project URL (example: https://xyzabc.supabase.co)
# [REQUIRED] - Get from Supabase dashboard
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Secret (for backend use)
# [REQUIRED] - Get from Settings → API → Service Role Secret (NOT Anon Key!)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inp5emFiYyIsInJvbGUiOiJzZXJ2aWNlX3JvbGUiLCJpYXQiOjE2MzAwMDAwMDAsImV4cCI6MTk0NjI5NTAwMH0.your-actual-key-here

# Supabase Storage Bucket name
# [REQUIRED] - Create bucket named "kdatahub-media" in Supabase dashboard
SUPABASE_STORAGE_BUCKET=kdatahub-media

# ─────────────────────────────────────────────────────────────────────────
# AWS S3 CONFIGURATION (Alternative to Supabase)
# ─────────────────────────────────────────────────────────────────────────
# Use either Supabase OR S3, not both

# Enable AWS S3 for file storage
USE_S3=False

# AWS S3 Bucket name (if USE_S3=True)
AWS_STORAGE_BUCKET_NAME=kdatahub-media

# AWS access key (if USE_S3=True)
AWS_S3_ACCESS_KEY_ID=your-access-key-id

# AWS secret access key (if USE_S3=True)
AWS_S3_SECRET_ACCESS_KEY=your-secret-access-key

# AWS S3 region
AWS_S3_REGION_NAME=us-east-1

# ─────────────────────────────────────────────────────────────────────────
# PAYSTACK CONFIGURATION [REQUIRED FOR PAYMENTS]
# ─────────────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.paystack.com → Settings → API Keys

# Paystack Public Key (pk_test_* for testing, pk_live_* for production)
# [REQUIRED] - Get from Paystack dashboard
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Paystack Secret Key (sk_test_* for testing, sk_live_* for production)
# [REQUIRED] - Get from Paystack dashboard (SECRET - do not expose!)
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# ─────────────────────────────────────────────────────────────────────────
# SMS CONFIGURATION [OPTIONAL - For notifications]
# ─────────────────────────────────────────────────────────────────────────
# Get API key from: https://app.arkesel.com → Dashboard → API

# Arkesel SMS API Key
# [OPTIONAL] - Leave blank if not using SMS notifications
ARKESEL_API_KEY=your-arkesel-api-key

# SMS Sender ID (appears in SMS messages)
SMS_SENDER_ID=KDATAHUB

# Manager phone number (receives order notifications)
# Format: +country-code followed by number
MANAGER_PHONE=+233594715103

# Admin phone number (receives alerts)
# Format: can be without country code if local
ADMIN_PHONE=0552514207

# ─────────────────────────────────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────────────────────────────────
# 1. This file is loaded via python-dotenv and should NOT be committed to git
# 2. Add .env to .gitignore (it should already be there)
# 3. For production (Render), set these in the Render dashboard instead
# 4. Use [REQUIRED] values for the app to work properly
# 5. Restart the server after changing any values: Ctrl+C then python manage.py runserver
