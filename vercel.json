{
  "buildCommand": "bash build_files.sh",
  "builds": [
    {
      "src": "kdatahub/wsgi.py",
      "use": "@vercel/python",
      "config": { 
        "maxLambdaSize": "15mb", 
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "kdatahub/wsgi.py"
    }
  ]
}
