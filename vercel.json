{
  "builds": [
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles_build"
      }
    },
    {
      "src": "kdatahub/wsgi.py",
      "use": "@vercel/python",
      "config": { 
        "maxLambdaSize": "15mb", 
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "staticfiles_build/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=86400, immutable"
      }
    },
    {
      "src": "/img/(.*)",
      "dest": "staticfiles_build/static/img/$1",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "src": "/css/(.*)",
      "dest": "staticfiles_build/static/css/$1",
      "headers": {
        "Cache-Control": "public, max-age=86400, immutable"
      }
    },
    {
      "src": "/js/(.*)",
      "dest": "staticfiles_build/static/js/$1",
      "headers": {
        "Cache-Control": "public, max-age=86400, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "kdatahub/wsgi.py"
    }
  ]
}
